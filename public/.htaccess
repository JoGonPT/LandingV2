<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force HTTPS and WWW (Optional but recommended for SEO/Security)
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^(.*)$ https://www.vruum.pt/$1 [L,R=301]

  # 2. Redirect root "/" to default locale "/pt/"
  RewriteRule ^$ /pt/ [L,R=301]

  # 3. Clean URLs: Serve .html files without the extension in the URL
  # Example: visitor goes to /pt, server serves /pt.html internally
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # 4. Redirect explicit .html requests to clean URLs for SEO
  # Example: visitor goes to /pt.html, redirect to /pt
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
  RewriteRule ^ %1 [R=301,L]

  # 5. Custom 404 page
  ErrorDocument 404 /404.html
</IfModule>
