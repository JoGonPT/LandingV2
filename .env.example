# --- TransferCRM B2B ---
# Base URL (any of these work; client normalizes to .../api/v2):
# https://way2go.transfercrm.com
# https://way2go.transfercrm.com/api
# https://way2go.transfercrm.com/api/v2
TRANSFERCRM_BASE_URL=https://your-slug.transfercrm.com/api/v2

TRANSFERCRM_AUTH_MODE=bearer
TRANSFERCRM_BEARER_TOKEN=tcrm_your_api_key_here
# TRANSFERCRM_API_KEY=
# TRANSFERCRM_API_SECRET=

TRANSFERCRM_TIMEOUT_MS=12000

# Optional: deep links from master-admin finance table to TransferCRM booking screens.
# Use {id} or {bookingId} for the CRM booking id (e.g. booking_id from the API).
# TRANSFERCRM_BOOKING_URL_TEMPLATE=https://your-tenant.transfercrm.com/admin/bookings/{id}

# Webhook: same secret as configured in TransferCRM for your endpoint
TRANSFERCRM_WEBHOOK_SECRET=replace_with_webhook_secret

# --- Stripe (checkout) ---
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# --- Address autocomplete ---
# Options: nominatim (default, OpenStreetMap) | google
PLACES_PROVIDER=nominatim
# Restrict suggestions to countries (ISO2, comma-separated)
PLACES_COUNTRIES=pt,es
# Required only when PLACES_PROVIDER=google
GOOGLE_MAPS_API_KEY=replace_with_google_places_api_key

# --- Driver PWA (drivers.way2go.pt rewrites to /drivers-pwa/*) ---
# Shared driver login (set strong password). Session cookie is signed with DRIVER_SESSION_SECRET.
DRIVER_LOGIN_EMAIL=driver@way2go.pt
DRIVER_LOGIN_PASSWORD=replace_with_long_random_password
DRIVER_SESSION_SECRET=replace_with_at_least_16_chars_random
# Optional session lifetime (seconds). Default: 604800 (7 days)
# DRIVER_SESSION_MAX_AGE_SEC=604800

# Notify your central system when a driver PATCHes travel_status (after TransferCRM accepts the update).
# Optional HMAC: hex digest sent as X-Way2Go-Signature: sha256=<hex>
# DRIVER_STATUS_WEBHOOK_URL=https://your-backend.example.com/hooks/driver-status
# DRIVER_STATUS_WEBHOOK_SECRET=replace_if_using_hmac

# --- Partner B2B portal (/partner/book and /partner/{slug}/book) ---
# Signed session cookie after POST /api/partner/auth (min 16 characters).
PARTNER_SESSION_SECRET=replace_with_at_least_16_chars_random
# Optional session lifetime (seconds). Default: 604800 (7 days)
# PARTNER_SESSION_MAX_AGE_SEC=604800

# Option A — multiple partners (JSON array):
# Optional: partnerKind (Hotel, Agency, …) for owner dashboards.
# PARTNERS_JSON=[{"slug":"hotel-lisboa","accessSecret":"long_random_shared_secret","displayName":"Hotel Lisboa","partnerKind":"Hotel"}]

# Option B — single partner (simpler):
# PARTNER_BOOKING_SLUG=hotel-lisboa
# PARTNER_BOOKING_SECRET=long_random_shared_secret
# PARTNER_BOOKING_DISPLAY_NAME=Hotel Lisboa

# --- Partner credit (EUR) — file store or Supabase ---
# Default limit for new partner rows (EUR). Usage is increased on "pay on account" bookings.
# PARTNER_DEFAULT_CREDIT_LIMIT_EUR=10000
# Optional JSON path (default: .data/partner-credits.json). Ignored when Supabase is configured.
# PARTNER_CREDIT_FILE=.data/partner-credits.json
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SQL: see supabase/migrations/*_partners_credit.sql (table public.partners:
# credit_limit, current_usage, commission_rate, pricing_model MARKUP|NET_PRICE, total_commissions_earned, …).

# --- Booking engine mode / traffic control ---
# STRICT_CRM | SHADOW_MODE | LOAD_BALANCE | STRICT_NATIVE
# BOOKING_ENGINE_MODE=SHADOW_MODE
# Native traffic ratio for LOAD_BALANCE mode (0..1). Default 0.2 (20%).
# BOOKING_ENGINE_NATIVE_RATIO=0.2

# --- Master admin (/internal/admin) — Way2Go owner ---
# Password for the admin login form. Session cookie is signed with the secret below.
W2G_MASTER_ADMIN_PASSWORD=replace_with_long_random_password
# Optional; defaults to PARTNER_SESSION_SECRET if unset (min 16 chars).
# W2G_MASTER_ADMIN_SESSION_SECRET=replace_with_at_least_16_chars_random
# W2G_MASTER_ADMIN_SESSION_MAX_AGE_SEC=43200

# --- Vercel ---
# Add every variable above in: Project → Settings → Environment Variables
# (Production + Preview as needed). Redeploy after changing secrets.
# Webhook URL for TransferCRM: https://YOUR_DOMAIN/api/webhooks/transfercrm
# Map hostname drivers.way2go.pt to this project; middleware rewrites it to /drivers-pwa/
