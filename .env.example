# --- TransferCRM B2B ---
# Base URL (any of these work; client normalizes to .../api/v2):
# https://way2go.transfercrm.com
# https://way2go.transfercrm.com/api
# https://way2go.transfercrm.com/api/v2
TRANSFERCRM_BASE_URL=https://your-slug.transfercrm.com/api/v2

TRANSFERCRM_AUTH_MODE=bearer
TRANSFERCRM_BEARER_TOKEN=tcrm_your_api_key_here
# TRANSFERCRM_API_KEY=
# TRANSFERCRM_API_SECRET=

TRANSFERCRM_TIMEOUT_MS=12000

# Optional: deep links from master-admin finance table to TransferCRM booking screens.
# Use {id} or {bookingId} for the CRM booking id (e.g. booking_id from the API).
# TRANSFERCRM_BOOKING_URL_TEMPLATE=https://your-tenant.transfercrm.com/admin/bookings/{id}

# Webhook: same secret as configured in TransferCRM for your endpoint
TRANSFERCRM_WEBHOOK_SECRET=replace_with_webhook_secret

# --- Stripe (checkout) ---
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# B2C: POST /api/payments/create-intent, GET /api/payments/checkout-status; Stripe webhook POST /api/webhooks/stripe (this app verifies with STRIPE_WEBHOOK_SECRET).
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Optional: set to 1 on Vercel to log `[middleware] API passthrough` for `/api/*` (Stripe webhooks, etc.).
# MIDDLEWARE_DEBUG_API=1

# --- Address autocomplete ---
# Options: nominatim (default, OpenStreetMap) | google
PLACES_PROVIDER=nominatim
# Restrict suggestions to countries (ISO2, comma-separated)
PLACES_COUNTRIES=pt,es
# Used by Places autocomplete when PLACES_PROVIDER=google
# and by route distance fallback (Google Directions) when TransferCRM requires `distance_km`.
GOOGLE_MAPS_API_KEY=replace_with_google_places_api_key

# --- TransferCRM embed widget (homepage form) ---
# Default booking UI mode on homepage: way2go | transfercrm
NEXT_PUBLIC_BOOKING_UI_MODE=way2go
# Optional UI switch buttons to change mode in runtime (1 = enabled)
NEXT_PUBLIC_BOOKING_UI_TOGGLE=1

NEXT_PUBLIC_TRANSFERCRM_WIDGET_SCRIPT_URL=https://transfercrm.com/api/widget-js/booking-v2.js
NEXT_PUBLIC_TRANSFERCRM_WIDGET_API=https://transfercrm.com/api
NEXT_PUBLIC_TRANSFERCRM_WIDGET_TENANT=way2go
NEXT_PUBLIC_TRANSFERCRM_WIDGET_LANG=pt
NEXT_PUBLIC_TRANSFERCRM_WIDGET_COLOR=#000000

# --- Public BFF → Nest (or cross-path calls on the same deployment) ---
# Prefer explicit base when Nest runs as a separate process (local: nestjs-api/, default port 3001).
NEST_API_BASE_URL=http://127.0.0.1:3001
#
# Production (Vercel): if NEST_API_BASE_URL is unset, the app uses NEXT_PUBLIC_SITE_URL, else https://${VERCEL_URL}.
# Use the canonical HTTPS origin (e.g. https://www.way2go.pt) so server-side fetch uses a real TLS certificate.
NEXT_PUBLIC_SITE_URL=https://www.example.com
#
# Optional: max time for each upstream fetch (ms). Default 60000, max 120000.
# NEST_PROXY_TIMEOUT_MS=60000
#
# NEST_QUOTE_PORT=3001
#
# POST /api/public/book requires Supabase (service role) to persist public.public_bookings before/after CRM sync.
# Optional: comma-separated driver_key values for driver_booking_assignments (first key wins; see DispatchService).
# PUBLIC_BOOK_DISPATCH_DRIVER_KEYS=key1,key2

# --- Driver PWA (drivers.way2go.pt rewrites to /drivers-pwa/*) ---
# Auth: Supabase (recommended). Set URL + anon key; drivers sign in with email/password (no public sign-up).
# Provision each driver in Supabase Dashboard → Authentication, then in public.profiles set id = auth user uuid,
# role = DRIVER, transfercrm_driver_id = TransferCRM chauffeur id (see supabase/migrations/*profiles_transfercrm*).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# Optional rollout fallback: if profiles.transfercrm_driver_id is null for the signed-in user, APIs use this env id.
# If both profile column and this env are unset, /api/drivers/bookings* and /api/driver/my-jobs return 503.
DRIVER_TRANSFERCRM_ID=123
# Optional: substring that must appear in booking external_reference to count as this driver's job
# when CRM does not expose driver assignment on B2B list/detail (partner-centric orders).
# DRIVER_BOOKING_REF_TOKEN=w2g-driver-unique-token

# Notify your central system when a driver PATCHes travel_status (after TransferCRM accepts the update).
# Optional HMAC: hex digest sent as X-Way2Go-Signature: sha256=<hex>
# DRIVER_STATUS_WEBHOOK_URL=https://your-backend.example.com/hooks/driver-status
# DRIVER_STATUS_WEBHOOK_SECRET=replace_if_using_hmac

# --- Partner B2B portal (/partner/book and /partner/{slug}/book) ---
# Signed session cookie after POST /api/partner/auth (min 16 characters).
PARTNER_SESSION_SECRET=replace_with_at_least_16_chars_random
# Optional session lifetime (seconds). Default: 604800 (7 days)
# PARTNER_SESSION_MAX_AGE_SEC=604800

# Option A — multiple partners (JSON array):
# Optional: partnerKind (Hotel, Agency, …) for owner dashboards.
# PARTNERS_JSON=[{"slug":"hotel-lisboa","accessSecret":"long_random_shared_secret","displayName":"Hotel Lisboa","partnerKind":"Hotel"}]

# Option B — single partner (simpler):
# PARTNER_BOOKING_SLUG=hotel-lisboa
# PARTNER_BOOKING_SECRET=long_random_shared_secret
# PARTNER_BOOKING_DISPLAY_NAME=Hotel Lisboa

# If SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, partners load from public.partners first.
# When that query returns no active rows (or fails open to []), the app falls back to PARTNERS_JSON / PARTNER_BOOKING_* above — so local .env partners still work with an empty partners table.

# --- Partner credit (EUR) — file store or Supabase ---
# Default limit for new partner rows (EUR). Usage is increased on "pay on account" bookings.
# PARTNER_DEFAULT_CREDIT_LIMIT_EUR=10000
# Optional JSON path (default: .data/partner-credits.json). Ignored when Supabase is configured.
# PARTNER_CREDIT_FILE=.data/partner-credits.json
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# When set, the driver PWA can read public.driver_booking_assignments (see
# supabase/migrations/*_driver_booking_assignments.sql). Use the service_role key
# only on the server (e.g. Vercel env), never in the browser.
# SQL: see supabase/migrations/*_partners_credit.sql (table public.partners:
# credit_limit, current_usage, commission_rate, pricing_model MARKUP|NET_PRICE, total_commissions_earned, …).

# --- Booking engine mode / traffic control ---
# STRICT_CRM | SHADOW_MODE | LOAD_BALANCE | STRICT_NATIVE
# BOOKING_ENGINE_MODE=SHADOW_MODE
# Native traffic ratio for LOAD_BALANCE mode (0..1). Default 0.2 (20%).
# BOOKING_ENGINE_NATIVE_RATIO=0.2

# --- Fiscal provider (Vendus) ---
# Admin HTTP (requires master-admin cookie): POST /api/faturamento/issue (payload = FiscalIssueInvoiceInput), POST /api/faturamento/issue-for-booking { bookingId }.
# PRODUCTION or MOCK
# VENDUS_MODE=MOCK
# VENDUS_API_KEY=replace_with_vendus_api_key
# Optional override (default: https://www.vendus.pt/ws/v1.1)
# VENDUS_BASE_URL=https://www.vendus.pt/ws/v1.1

# --- Master admin (/internal/admin) — Way2Go owner ---
# Password for the admin login form. Session cookie is signed with the secret below.
# Demo (optional): W2G_MASTER_ADMIN_PASSWORD=W2G-Demo-Admin-2026!
# W2G_MASTER_ADMIN_SESSION_SECRET=w2g_dev_master_admin_sess_16
W2G_MASTER_ADMIN_PASSWORD=replace_with_long_random_password
# Optional; defaults to PARTNER_SESSION_SECRET if unset (min 16 chars).
# W2G_MASTER_ADMIN_SESSION_SECRET=replace_with_at_least_16_chars_random
# W2G_MASTER_ADMIN_SESSION_MAX_AGE_SEC=43200

# --- Vercel ---
# Add every variable above in: Project → Settings → Environment Variables
# (Production + Preview as needed). Redeploy after changing secrets.
# Webhook URL for TransferCRM: https://YOUR_DOMAIN/api/webhooks/transfercrm
# Map hostname drivers.way2go.pt to this project; middleware rewrites it to /drivers-pwa/

# --- Supabase CLI (apply migrations to hosted project) ---
# 1) Install CLI: npx supabase --version
# 2) Link once (interactive): npx supabase link --project-ref YOUR_PROJECT_REF
# 3) Push pending SQL from supabase/migrations/: npm run db:push
#    Dry run: npm run db:push:dry
# Without link, use direct Postgres URL (from Supabase Dashboard → Connect):
# npx supabase db push --db-url "postgresql://postgres.[ref]:[PASSWORD]@...pooler...:6543/postgres" --yes
